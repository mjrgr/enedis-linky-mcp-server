# ── Required ──────────────────────────────────────────────────────────────────

# Conso API bearer token.
# Obtain yours at: https://conso.boris.sh
CONSO_API_TOKEN=your_token_here

# ── Optional ──────────────────────────────────────────────────────────────────

# MCP transport: "stdio" (default, for Claude Desktop) or "sse" (HTTP server)
MCP_TRANSPORT=stdio

# HTTP port used when MCP_TRANSPORT=sse (default: 8080)
PORT=8080

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Override the Conso API base URL (useful for testing with a mock server)
# CONSO_API_BASE_URL=https://conso.boris.sh/api
