# ── Required ──────────────────────────────────────────────────────────────────

# Conso API bearer token.
# Obtain yours at: https://conso.boris.sh
CONSO_API_TOKEN=your_token_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Default PRM (Point de Référence de Mesure) — the meter's unique 14-digit identifier.
# When set, the prm parameter becomes optional in all MCP tool calls and is pre-filled in the dashboard.
# LINKY_PRM=12345678901234

# MCP transport: "stdio" (default, for Claude Desktop) or "sse" (HTTP server)
MCP_TRANSPORT=stdio

# HTTP port used when MCP_TRANSPORT=sse (default: 8080)
PORT=8080

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Override the Conso API base URL (useful for testing with a mock server)

# CONSO_API_BASE_URL=https://conso.boris.sh/api

# Enable the web dashboard (default: false)
LINKY_DASHBOARD=false

# Listen address for the dashboard (default: :8081)
LINKY_DASH_ADDR=:8081
