{
  "formatters": {
    "enable": [
      "gofmt",
      "goimports"
    ],
    "exclusions": {
      "generated": "lax",
      "paths": [
        "third_party$",
        "builtin$",
        "examples$"
      ]
    }
  },
  "issues": {
    "max-issues-per-linter": 50,
    "max-same-issues": 3
  },
  "linters": {
    "enable": [
      "gocritic"
    ],
    "exclusions": {
      "generated": "lax",
      "paths": [
        "third_party$",
        "builtin$",
        "examples$"
      ],
      "presets": [
        "comments",
        "common-false-positives",
        "legacy",
        "std-error-handling"
      ]
    },
    "settings": {
      "gocritic": {
        "enabled-checks": [
          "appendAssign",
          "dupBranchBody",
          "dupCase",
          "equalFold",
          "sloppyLen"
        ]
      }
    }
  },
  "version": "2"
}
